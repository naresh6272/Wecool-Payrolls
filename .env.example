# Copy this file to .env and fill in your values

# Local SQLite (development only)
DATABASE_URL="file:./prisma/dev.db"

# Turso cloud SQLite (production — required for Vercel deployment)
# Get these from https://turso.tech after creating a database
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET="change-me-to-a-strong-random-secret"

NEXTAUTH_URL="http://localhost:3000"

# Resend email service — get your key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Wecool Payroll <hr@yourdomain.com>"
